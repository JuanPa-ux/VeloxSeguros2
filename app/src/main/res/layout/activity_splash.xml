<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_splash.xml
    Splash minimalista: logo + nombre centrados sobre fondo negro.
    Sin animaciones de XML (se hacen en código con alpha fade).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Grupo central: ícono + nombre -->
    <LinearLayout
        android:id="@+id/layoutLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ícono escudo: 48dp, tintado blanco puro -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_shield"
            android:contentDescription="Velox Seguros"
            app:tint="@color/colorTextPrimary"
            android:layout_marginBottom="16dp"/>

        <!-- Nombre de la app en dos líneas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VELOX"
            android:textColor="@color/colorTextPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.20"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEGUROS"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.35"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Versión pequeña en la esquina inferior -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textColor="@color/colorTextHint"
        android:textSize="10sp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
