<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_cotizar.xml
    Cotizador minimalista:
    - Título + subtítulo
    - 3 spinners con etiquetas (Modelo, Año, Color)
    - Sección "Planes" con 2 tarjetas seleccionables
    - Botón "Contratar ahora"
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:paddingBottom="80dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva cotización"
            android:textColor="@color/colorTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona tu Nissan y elige un plan"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="28dp"/>

        <!-- ─── DATOS DEL VEHÍCULO ─── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DATOS DEL VEHÍCULO"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <!-- Modelo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modelo"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinnerModelo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_selector"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginBottom="16dp"/>

        <!-- Año -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Año"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinnerAnio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_selector"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginBottom="16dp"/>

        <!-- Color -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Color"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinnerColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_selector"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginBottom="28dp"/>

        <!-- ─── PLANES ─── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLANES DISPONIBLES"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <!-- Plan Básico -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlanBasico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Indicador de selección -->
                <View
                    android:id="@+id/dotBasico"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_circle_surface"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvPlanBasico"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plan Básico"
                        android:textColor="@color/colorTextPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cobertura esencial · Daños a terceros"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/tvMontoBasico"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$890"
                        android:textColor="@color/colorTextPrimary"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/mes"
                        android:textColor="@color/colorTextHint"
                        android:textSize="10sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Plan Total -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlanTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Indicador de selección (activo por defecto = índigo) -->
                <View
                    android:id="@+id/dotTotal"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvPlanTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plan Total"
                            android:textColor="@color/colorTextPrimary"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                        <!-- Badge "Popular" -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Popular"
                            android:background="@drawable/bg_badge_green"
                            android:textColor="@color/colorSuccess"
                            android:textSize="9sp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cobertura completa · Robo · Gastos médicos"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/tvMontoTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$1,450"
                        android:textColor="@color/colorPrimaryLight"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/mes"
                        android:textColor="@color/colorTextHint"
                        android:textSize="10sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón contratar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContratar"
            style="@style/Widget.Velox.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contratar ahora"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
