<?xml version="1.0" encoding="utf-8"?>
<!--
    item_movimiento.xml
    Fila de movimiento reciente en Home:
    - Ícono circular a la izquierda
    - Descripción + fecha
    - Monto alineado a la derecha
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp">

    <!-- Ícono circular -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_surface"/>

        <ImageView
            android:id="@+id/ivIconoMovimiento"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_credit_card"
            android:contentDescription="Movimiento"
            app:tint="@color/colorPrimaryLight"/>

    </FrameLayout>

    <!-- Descripción + fecha -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDescripcionMovimiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvFechaMovimiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextHint"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Monto -->
    <TextView
        android:id="@+id/tvMontoMovimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/colorTextPrimary"
        android:textSize="13sp"
        android:textStyle="bold"/>

</LinearLayout>
