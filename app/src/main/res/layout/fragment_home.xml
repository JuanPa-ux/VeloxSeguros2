<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml
    Dashboard principal:
    - Header: saludo + botón notificaciones
    - Tarjeta de póliza activa (fondo oscuro, borde índigo sutil)
    - Acciones rápidas en cuadrícula 2x2
    - Lista de movimientos recientes
    - Botón cerrar sesión
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:paddingBottom="80dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ─── HEADER ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola de nuevo,"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/btnNotificaciones"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="8dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="Notificaciones"
                app:tint="@color/colorTextPrimary"/>

        </LinearLayout>

        <!-- ─── TARJETA PÓLIZA ACTIVA ─── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPolizaActiva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Barra de acento lateral -->
                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorPrimary"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PÓLIZA ACTIVA"
                        android:textColor="@color/colorPrimary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvModeloVehiculo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nissan Versa 2022"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvEstadoPolizaHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activa"
                            android:background="@drawable/bg_badge_green"
                            android:textColor="@color/colorSuccess"
                            android:textSize="10sp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"/>

                    </LinearLayout>

                    <!-- Detalles del vehículo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Placas"
                                android:textColor="@color/colorTextHint"
                                android:textSize="10sp"/>

                            <TextView
                                android:id="@+id/tvPlacasHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ABC-123"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vence"
                                android:textColor="@color/colorTextHint"
                                android:textSize="10sp"/>

                            <TextView
                                android:id="@+id/tvVencimientoHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="31 Dic 2026"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Plan"
                                android:textColor="@color/colorTextHint"
                                android:textSize="10sp"/>

                            <TextView
                                android:id="@+id/tvPlanHome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textColor="@color/colorPrimaryLight"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ─── ACCIONES RÁPIDAS ─── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCIONES RÁPIDAS"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="28dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <!-- Cotizar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCotizar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_file_text"
                        android:contentDescription="Cotizar"
                        app:tint="@color/colorPrimaryLight"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cotizar"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nuevo seguro"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mis pólizas -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPolizas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_shield"
                        android:contentDescription="Pólizas"
                        app:tint="@color/colorPrimaryLight"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pólizas"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver mis seguros"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pagar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPagar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_credit_card"
                        android:contentDescription="Pagar"
                        app:tint="@color/colorPrimaryLight"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pagar"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mensualidad"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Soporte -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSoporte"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_phone"
                        android:contentDescription="Soporte"
                        app:tint="@color/colorPrimaryLight"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soporte"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contactar agente"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ─── MOVIMIENTOS RECIENTES ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RECIENTES"
                android:textColor="@color/colorTextHint"
                android:textSize="10sp"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/tvVerTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver todos"
                android:textColor="@color/colorPrimaryLight"
                android:textSize="11sp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMovimientos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"/>

        <!-- ─── CERRAR SESIÓN ─── -->
        <!-- ← NUEVO: botón al fondo del scroll, separado visualmente -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:background="@color/colorSurface"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarSesion"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:text="Cerrar sesión"
            android:textColor="@color/colorError"
            app:strokeColor="@color/colorError"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>